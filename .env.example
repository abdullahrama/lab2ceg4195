# ── Dataset download (Kaggle API) ─────────────────────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Training ──────────────────────────────────────────────────────────────────
MODEL_SAVE_PATH=models/unet_resnet34.pth
BATCH_SIZE=16
EPOCHS=30
LEARNING_RATE=0.0001
SEG_THRESHOLD=0.5

# ── Flask API ─────────────────────────────────────────────────────────────────
MODEL_PATH=models/unet_resnet34.pth
PORT=5000
